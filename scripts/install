#!/usr/bin/env bash

set -euo pipefail
shopt -s nullglob

# Enable debugging if the DEBUG environment variable is set to 1.
if [ "${DEBUG:-}" = "1" ]; then set -x; fi

# Get path to the root of the repository.
DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )/.." >/dev/null 2>&1 && pwd -P)"

# Install dotfiles.

# Files to be linked into the home directory.
LINK_FILES=(".bashrc" ".colorgccrc" ".editorconfig" ".lintr" ".makepkg.conf" ".Rprofile" ".vimrc")

# TODO: CLI/Configuration options.
DRY_RUN=0
OVERWRITE=0
VERBOSE=0

# Print the specified error message and exit with a non-zero status.
die() {
    echo "${1}" >&2
    exit 1
}

# Create a backup filename for the specified file.
create_backup_filename() {
    # DST is absolute path + file name.
    DST="${1}"
    DEFAULT="${DST}.bak"
    if [ ! -e "${DEFAULT}" ]; then
        echo "${DEFAULT}"
    else
        TIMESTAMP="$(date +%Y%m%d%H%M%S)"
        echo "${DST}.${TIMESTAMP}.bak"
    fi
}

# Install the specified file into the destination. Used internally by install().
install_file() {
    SRC="${1}"
    DST="${2}"

    if [ "${DRY_RUN}" = 1 -o "${VERBOSE}" = 1 ]; then
        echo "ln -sf -- \"${SRC}\" \"${DST}\""
    fi

    if [ "${DRY_RUN}" = 0 ]; then
        ln -sf -- "${SRC}" "${DST}"
    fi
}

# Install the specified file into the destination.
install() {
    SRC="${1}"
    DST="${2}"

    # Allow for destination to be a directory into which the file should be
    # linked. E.g. `ln -s .bashrc ~/`
    if [ -d "${DST}" ]; then
        DST="${DST}/$(basename "${SRC}")"
    fi

    if [ ! -f "${SRC}" ]; then
        # Source file does not exist.
        die "Source file \"${SRC}\" does not exist"
    elif [ -L "${DST}" ]; then
        # Destination already exists and is a symlink.
        ABS_DST="$(readlink -f -- "${DST}" 2>/dev/null || true)"
        if [ -z "${ABS_DST}" ]; then
            # Destination is a dangling symlink. Always overwrite.
            echo "WARNING: Dangling symlink \"${DST}\" found. This will be overwritten."
            install_file "${SRC}" "${DST}"
        elif [ "${ABS_DST}" = "${SRC}" ]; then
            # Destination is already linked to the source. Do nothing.
            echo "Destination file \"${DST}\" already linked to \"${SRC}\""
        else
            # Destination is linked to another file. Conditionally overwrite.
            if [ "${OVERWRITE}" = 1 ]; then
                echo "WARNING: Destination file \"${DST}\" already linked to \"${ABS_DST}\". Overwriting..."
                install_file "${SRC}" "${DST}"
            else
                echo "WARNING: Destination file \"${DST}\" already linked to \"${ABS_DST}\"."
            fi
        fi
    elif [ -f "${DST}" ]; then
        # Destination file exists (but not a symlink).
        if [ "${OVERWRITE}" = 1 ]; then
            # Backup the existing file and symlink to the source file.
            BAK="$(create_backup_filename "${DST}")"
            if [ "${DRY_RUN}" = 1 -o "${VERBOSE}" = 1 ]; then
                echo "Existing file: \"${DST}\" will be backed up to: \"${BAK}\""
            fi
            if [ "${DRY_RUN}" = 0 ]; then
                mv "${DST}" "${BAK}"
            fi
            install_file "${SRC}" "${DST}"
        else
            # Destination file exists and overwrite mode is disabled.
            die "Destination file \"${DST}\" already exists"
        fi
    else
        # Destination file does not exist. Create a symlink.
        install_file "${SRC}" "${DST}"
    fi
}

# Install files to home directory.
for FILE in "${LINK_FILES[@]}"
do
    install "${DIR}/${FILE}" "${HOME}/$(basename "${FILE}")"
done

# Install vscode files.
VSCODE_DIR="${HOME}/.config/Code/User"
mkdir -p "${VSCODE_DIR}"
for FILE in "${DIR}/vscode"/*
do
    install "${FILE}" "${VSCODE_DIR}/$(basename "${FILE}")"
done

# Install windsurf files.
WINDSURF_DIR="${HOME}/.config/Windsurf/User"
mkdir -p "${WINDSURF_DIR}"
for FILE in "${DIR}/windsurf"/*
do
    install "${FILE}" "${WINDSURF_DIR}/$(basename "${FILE}")"
done
